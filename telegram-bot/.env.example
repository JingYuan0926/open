# Telegram bot token from @BotFather (https://t.me/BotFather → /newbot)
BOT_TOKEN=123456:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# 0G testnet wallet private key (hex, with or without 0x).
# Must already have a funded ledger account — see parent monorepo's
# pages/api/0g/compute-setup-account.ts (action=create-ledger / deposit).
# Faucet: https://faucet.0g.ai
0G_PRIVATE_KEY=0xabc123...

# ── Optional overrides ──

# 0G testnet RPC (default: https://evmrpc-testnet.0g.ai)
# ZG_RPC=https://evmrpc-testnet.0g.ai

# Conversation history depth, in user/assistant turns (default: 10)
# HISTORY_LIMIT=10

# Per-call timeout for 0G inference, in milliseconds (default: 60000)
# REQUEST_TIMEOUT_MS=60000

# Override the bot's persona / instructions
# SYSTEM_PROMPT="You are a helpful assistant..."
